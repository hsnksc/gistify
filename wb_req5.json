{"action":"evaluate","args":{"code":"(()=>{const tables=document.querySelectorAll('table');const tableDetails=Array.from(tables).slice(0,3).map(t=>{const firstRow=t.querySelector('tr');const firstCell=t.querySelector('td,th');return {rows:t.querySelectorAll('tr').length,headerBg:firstRow?getComputedStyle(firstRow).backgroundColor:null,cellPadding:firstCell?getComputedStyle(firstCell).padding:null,cellFontSize:firstCell?getComputedStyle(firstCell).fontSize:null,borderCollapse:getComputedStyle(t).borderCollapse,fontSize:getComputedStyle(t).fontSize};});const badges=document.querySelectorAll('span[class*=\"badge\"],div[class*=\"badge\"],span[class*=\"pill\"],div[class*=\"pill\"],span[class*=\"tag\"],div[class*=\"tag\"]');const badgeDetails=Array.from(badges).slice(0,10).map(b=>({text:b.textContent.trim().slice(0,20),bg:getComputedStyle(b).backgroundColor,color:getComputedStyle(b).color,br:getComputedStyle(b).borderRadius,padding:getComputedStyle(b).padding,fontSize:getComputedStyle(b).fontSize,fontWeight:getComputedStyle(b).fontWeight,border:getComputedStyle(b).border}));const emptyStates=document.querySelectorAll('[class*=\"empty\"],[class*=\"skeleton\"],[class*=\"placeholder\"],[class*=\"blank\"]');const emptyDetails=Array.from(emptyStates).slice(0,5).map(e=>({text:e.textContent.trim().slice(0,30),className:e.className,bg:getComputedStyle(e).backgroundColor,color:getComputedStyle(e).color,br:getComputedStyle(e).borderRadius,padding:getComputedStyle(e).padding,fontSize:getComputedStyle(e).fontSize}));const allCards=document.querySelectorAll('div[class*=\"card\"],div[class*=\"glass\"],div[class*=\"panel\"]');const cardGap=Array.from(allCards).map(c=>{const parent=c.parentElement;return parent?{parentDisplay:getComputedStyle(parent).display,parentGap:getComputedStyle(parent).gap,parentPadding:getComputedStyle(parent).padding}:null;}).filter(x=>x);const main=document.querySelector('main');const section=document.querySelector('section');const container=document.querySelector('div[class*=\"container\"]');return JSON.stringify({tableDetails,badgeDetails,emptyDetails,cardGap:cardGap.slice(0,5),main:main?{padding:getComputedStyle(main).padding,gap:getComputedStyle(main).gap}:null,section:section?{padding:getComputedStyle(section).padding,gap:getComputedStyle(section).gap}:null,container:container?{maxWidth:getComputedStyle(container).maxWidth,padding:getComputedStyle(container).padding,margin:getComputedStyle(container).margin}:null});})()"},"session":"gistify-dashboard-visual"}