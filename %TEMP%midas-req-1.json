action:evaluate args:{code:(() => {\n  const chart = document.querySelector('[class*=MultiChartContainer]') || document.querySelector('[class*=Chart]');\n  const hierarchy = [];\n  let el = chart;\n  while (el && el.tagName !== 'BODY') {\n    hierarchy.push({tag:el.tagName, id:el.id, class:(el.className||'').substring(0,120)});\n    el = el.parentElement;\n  }\n  return JSON.stringify(hierarchy.reverse());\n})()} session:midas-chart-analysis
