# Server runtime
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=change-me
BILLING_DB_PATH=./data/billing.sqlite

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/api/auth/google/callback

# Manual pro allow-list fallback (comma separated emails)
SUBSCRIBED_EMAILS=

# Shopier monthly billing
SHOPIER_SUBSCRIPTION_PRODUCT_URL=
SHOPIER_SUBSCRIPTION_PRODUCT_ID=
SHOPIER_SUBSCRIPTION_PRODUCT_TITLE=
SHOPIER_SHOP_URL=
SHOPIER_MONTHLY_PRICE=300.00
SHOPIER_CURRENCY=TRY
SHOPIER_SUBSCRIPTION_DAYS=30
SHOPIER_PAT=
SHOPIER_APP_CLIENT_ID=
SHOPIER_APP_CLIENT_SECRET=
SHOPIER_WEBHOOK_TOKEN=
SHOPIER_WEBHOOK_MAX_AGE_SECONDS=300
SHOPIER_ALLOW_ANY_PRODUCT_ORDER=false
SHOPIER_AUTO_REGISTER_WEBHOOK=false
# For local manual tests only. Keep false in production.
SHOPIER_ALLOW_LEGACY_WEBHOOK_TOKEN=false

# Optional analytics placeholders used by index.html
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
