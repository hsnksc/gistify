# Server runtime
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
APP_ACCESS_MODE=managed
SESSION_SECRET=change-me
BILLING_DB_PATH=./data/billing.sqlite

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/api/auth/google/callback

# Weekly report admin
REPORT_ADMIN_EMAIL=hsnksc@gmail.com
REPORT_ADMIN_SECRET=
FMP_API_KEY=
# Canonical options/market-data adapter. The endpoint must return the contract
# documented in docs/earnings-options-engine.md.
OPTIONS_DATA_PROVIDER_URL=
OPTIONS_DATA_API_KEY=
OPTIONS_DATA_PROVIDER_NAME=
OPTIONS_DATA_AUTH_HEADER=Authorization
OPTIONS_DATA_AUTH_PREFIX="Bearer "
OPTIONS_DATA_TIMEOUT_MS=12000
OPTIONS_DATA_CONCURRENCY=4

# ThetaData v3 local Terminal adapter. Free accounts provide delayed EOD data.
OPTIONS_DATA_PROVIDER=
THETADATA_API_KEY=
THETADATA_BASE_URL=http://127.0.0.1:25503/v3
THETADATA_MAX_TICKERS=8
THETADATA_MAX_DTE=60
THETADATA_STRIKE_RANGE=15
THETADATA_REQUEST_GAP_MS=3100

# MarketFlash source selection: marketdata, thetadata, or yahoo. When left
# empty, MarketData is tried first, then configured ThetaData, then Yahoo.
MARKETFLASH_DATA_SOURCE=
MARKETFLASH_THETADATA_MAX_TICKERS=40
MARKETFLASH_THETADATA_TIMEOUT_MS=60000

# Optional critical-alert webhook (Slack/Teams/automation gateway adapter).
EARNINGS_ALERT_WEBHOOK_URL=
EARNINGS_ALERT_WEBHOOK_SECRET=
EARNINGS_ALERT_COOLDOWN_MS=21600000
OPENAI_API_KEY=
OPENAI_IMAGE_MAIN_MODEL=gpt-4.1

# Mistral translation fallback (highest quality: mistral-medium-latest)
MISTRAL_API_KEY=
MISTRAL_TRANSLATION_MODEL=
# Model used by scripts/coverage_research.py (/gistcoverage) — default mistral-large-latest
MISTRAL_MODEL=
DAILY_REPORTS_PATH=./dailyreport
COVERAGE_REPORTS_PATH=./reports/coverage

# Manual pro allow-list fallback (comma separated emails)
SUBSCRIBED_EMAILS=
ELITE_EMAILS=

# Paddle placeholders
PADDLE_ENV=live
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_PRODUCT_ID=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
PADDLE_SUCCESS_URL=http://localhost:3000/pay?billing=success
PADDLE_CANCEL_URL=http://localhost:3000/pay?billing=cancel

# Public site URL used for canonical links, OG tags and sitemaps
PUBLIC_SITE_URL=http://localhost:3000

# Prerender.io token for search-engine friendly SPA snapshots
PRERENDER_TOKEN=

# Optional analytics placeholders used by index.html
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Optional GA4 override. index.html uses G-D87NYSSNP0 by default.
VITE_GA4_ID=

# Hotjar Site ID (numeric)
VITE_HOTJAR_SITE_ID=

# Optional scanner fallback providers. Yahoo remains the default source.
VITE_SCANNER_MASSIVE_API_KEY=
VITE_SCANNER_TWELVEDATA_API_KEY=
VITE_SCANNER_ALPHAVANTAGE_API_KEY=
