# Server runtime
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
APP_ACCESS_MODE=managed
SESSION_SECRET=change-me
BILLING_DB_PATH=./data/billing.sqlite

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/api/auth/google/callback

# Weekly report admin
REPORT_ADMIN_EMAIL=hsnksc@gmail.com
REPORT_ADMIN_SECRET=
FMP_API_KEY=
OPENAI_API_KEY=
OPENAI_IMAGE_MAIN_MODEL=gpt-4.1

# Mistral translation fallback (highest quality: mistral-medium-latest)
MISTRAL_API_KEY=
MISTRAL_TRANSLATION_MODEL=
DAILY_REPORTS_PATH=./dailyreport
COVERAGE_REPORTS_PATH=./reports/coverage

# Manual pro allow-list fallback (comma separated emails)
SUBSCRIBED_EMAILS=
ELITE_EMAILS=

# Paddle placeholders
PADDLE_ENV=live
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_PRODUCT_ID=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
PADDLE_SUCCESS_URL=http://localhost:3000/pay?billing=success
PADDLE_CANCEL_URL=http://localhost:3000/pay?billing=cancel

# Public site URL used for canonical links, OG tags and sitemaps
PUBLIC_SITE_URL=http://localhost:3000

# Prerender.io token for search-engine friendly SPA snapshots
PRERENDER_TOKEN=

# Optional analytics placeholders used by index.html
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA4_ID=

# Hotjar Site ID (numeric)
VITE_HOTJAR_SITE_ID=

# Optional scanner fallback providers. Yahoo remains the default source.
VITE_SCANNER_MASSIVE_API_KEY=
VITE_SCANNER_TWELVEDATA_API_KEY=
VITE_SCANNER_ALPHAVANTAGE_API_KEY=
