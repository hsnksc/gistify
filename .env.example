# Server runtime
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
APP_ACCESS_MODE=public
SESSION_SECRET=change-me
BILLING_DB_PATH=./data/billing.sqlite

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/api/auth/google/callback

# Manual pro allow-list fallback (comma separated emails)
SUBSCRIBED_EMAILS=

# Paddle placeholders
PADDLE_ENV=live
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_PRODUCT_ID=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
PADDLE_SUCCESS_URL=http://localhost:3000/?billing=success
PADDLE_CANCEL_URL=http://localhost:3000/?billing=cancel

# Optional analytics placeholders used by index.html
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Optional scanner fallback providers. Yahoo remains the default source.
VITE_SCANNER_MASSIVE_API_KEY=
VITE_SCANNER_TWELVEDATA_API_KEY=
VITE_SCANNER_ALPHAVANTAGE_API_KEY=
